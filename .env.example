# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=My SaaS

# === Database ===
DB_NAME=saas
DB_USER=saas
DB_PASSWORD=changeme

# Full connection string — update host to 'db' inside Docker, 'localhost' outside
DATABASE_URL=postgresql://saas:changeme@db:5432/saas

# === Redis ===
REDIS_URL=redis://redis:6379

# === Auth ===
# Generate with: openssl rand -base64 32
AUTH_SECRET=generate-a-32-char-secret-here

# === OAuth (optional — leave blank to disable) ===
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Email ===
# Options: smtp | resend | ses
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@yourdomain.com

# SMTP (use mailhog in dev, any SMTP server in production)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# Resend (only required when EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# AWS SES (only required when EMAIL_PROVIDER=ses)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# === Billing ===
# Options: stripe | paddle
BILLING_PROVIDER=stripe

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create these in your Stripe dashboard
STRIPE_PRICE_ID_PRO_MONTHLY=price_...
STRIPE_PRICE_ID_PRO_ANNUAL=price_...
STRIPE_PRICE_ID_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ID_ENTERPRISE_ANNUAL=price_...

# Paddle (only required when BILLING_PROVIDER=paddle)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_ID_PRO_MONTHLY=
PADDLE_PRICE_ID_PRO_ANNUAL=

# === Analytics (Umami) ===
# Generate with: openssl rand -base64 32
UMAMI_APP_SECRET=changeme-umami-secret

# Get this from your Umami dashboard after first login
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_URL=http://localhost:3001

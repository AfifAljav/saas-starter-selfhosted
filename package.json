{
  "name": "saas-starter-selfhosted",
  "version": "1.0.0",
  "private": true,
  "description": "Open-source, self-hostable SaaS boilerplate — auth, billing, multi-tenancy, Docker Compose. No Vercel, no Supabase.",
  "homepage": "https://github.com/AfifAljav/saas-starter-selfhosted",
  "repository": {
    "type": "git",
    "url": "https://github.com/AfifAljav/saas-starter-selfhosted.git"
  },
  "license": "MIT",
  "author": "AfifAljav",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "email:dev": "turbo email:dev"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "prettier": "^3.5.3",
    "@types/node": "^22.15.29",
    "eslint": "^9.28.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.9.2"
}
